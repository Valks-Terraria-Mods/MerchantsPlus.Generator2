<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:MerchantsPlus.Generator"
        x:Class="MerchantsPlus.Generator.MainWindow"
        x:Name="RootWindow"
        Width="1920"
        Height="1080"
        MinWidth="960"
        MinHeight="640"
        FontFamily="avares://Avalonia.Fonts.Inter#Inter"
        FontSize="{Binding AppFontSize}"
        Tag="{Binding TreeViewFontSize, FallbackValue=14, TargetNullValue=14}"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="MerchantsPlus Catalog"
        mc:Ignorable="d">

  <Window.Resources>
    <local:MultiplyDoubleConverter x:Key="MultiplyDoubleConverter" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#131517" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#131517" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#3C434D" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#CDD2DA" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A9B1BC" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#23272D" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3B414A" />
    <SolidColorBrush x:Key="InputBorderFocusedBrush" Color="#5B6572" />
    <SolidColorBrush x:Key="ListBackgroundBrush" Color="#1A1D22" />
    <SolidColorBrush x:Key="TextControlBackground" Color="#23272D" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#23272D" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#23272D" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3B414A" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3B414A" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="TextBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
    </Style>

    <Style Selector="TextBox:focus, TextBox:focus-within">
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderFocusedBrush}" />
    </Style>

    <Style Selector="ListBox">
      <Setter Property="Background" Value="{DynamicResource ListBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <local:CatalogViewModel />
  </Design.DataContext>

  <Grid Margin="18" RowDefinitions="Auto,*,Auto">
    <Menu Grid.Row="0" Margin="0,0,0,10">
      <MenuItem Header="File">
        <MenuItem Header="Settings" Click="OnOpenSettingsClick" />
        <MenuItem Header="Force Refresh" Click="OnForceRefreshClick" />
        <MenuItem Header="Exit" Click="OnExitClick" />
      </MenuItem>
      <MenuItem Header="Edit">
        <MenuItem Header="Global Flags" Click="OnOpenGlobalFlagsClick" />
      </MenuItem>
    </Menu>

    <TabControl x:Name="WorkspaceTabs" Grid.Row="1" SelectedIndex="{Binding WorkspaceTabIndex}" Margin="0,0,0,0">
      <TabItem Header="Items">
        <Grid Margin="0,8,0,0" ColumnDefinitions="300,1.6*,1.4*">
          <Border Grid.Column="0" Padding="12" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,7,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <TextBlock Text="Item Catalog" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.2857142857, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBox Grid.Row="1"
                       Margin="0,10,0,10"
                       Watermark="Filter categories and shops..."
                       Text="{Binding CatalogTreeFilterText}" />
              <TreeView Grid.Row="2" Margin="0,0,0,10" FontSize="{Binding TreeViewFontSize, FallbackValue=14, TargetNullValue=14}" ItemsSource="{Binding FilteredRootNodes}" SelectedItem="{Binding SelectedNode}" ContextRequested="OnCatalogTreeContextRequested">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate DataType="local:CatalogNode" ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                      <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0" VerticalAlignment="Center">
                        <local:CountBadgeView IsVisible="{Binding HasItemCountBadge}"
                                              BadgeText="{Binding ItemCountBadgeText}"
                                              BadgeBackground="#024630"
                                              BadgeForeground="#F8FAFC" />
                        <local:CountBadgeView IsVisible="{Binding HasShopCountBadge}"
                                              BadgeText="{Binding ShopCountBadgeText}"
                                              BadgeBackground="#33597a"
                                              BadgeForeground="#F8FAFC" />
                      </StackPanel>
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                  <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                  </Style>
                </TreeView.Styles>
              </TreeView>
              <TextBlock Grid.Row="3" Text="{Binding HeaderStats}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            </Grid>
          </Border>

          <Border Grid.Column="1" Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="7,0,7,0" MinWidth="420">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Text="{Binding CenterPanelTitle}" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.5714285714, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          Width="180"
                          Margin="10,0,0,0"
                          ItemsSource="{Binding CenterPanelSplitModes}"
                          SelectedItem="{Binding MiddlePanelSplitMode}" />
              </Grid>
              <TextBox Grid.Row="1"
                       Margin="0,10,0,10"
                       Watermark="Filter selected shop items..."
                       Text="{Binding FilterText}" />
              <Grid Grid.Row="2">
                <ListBox IsVisible="{Binding IsCenterPanelSingleView}" ItemsSource="{Binding VisibleItems}" SelectedItem="{Binding SelectedVisibleItem}" DoubleTapped="OnItemRowDoubleTapped">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      <Setter Property="ContextMenu">
                        <ContextMenu>
                          <MenuItem Header="Exclude Item" Click="OnExcludeItemClick" />
                        </ContextMenu>
                      </Setter>
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <local:CatalogItemRowView />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Grid IsVisible="{Binding IsCenterPanelSplitVertically}" ColumnDefinitions="*,8,*" RowDefinitions="Auto,*">
                  <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" Text="{Binding PrimaryPanelTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,8" Text="{Binding SecondaryPanelTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding VisibleItems}" SelectedItem="{Binding SelectedVisibleItem}" DoubleTapped="OnItemRowDoubleTapped">
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="ContextMenu">
                          <ContextMenu>
                            <MenuItem Header="Exclude Item" Click="OnExcludeItemClick" />
                          </ContextMenu>
                        </Setter>
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <local:CatalogItemRowView />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <GridSplitter Grid.RowSpan="2" Grid.Column="1" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Stretch" />
                  <ListBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding SecondaryVisibleItems}" DoubleTapped="OnItemRowDoubleTapped">
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <local:CatalogItemRowView />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>

                <Grid IsVisible="{Binding IsCenterPanelSplitHorizontally}" RowDefinitions="Auto,*,8,Auto,*">
                  <TextBlock Grid.Row="0" Margin="0,0,0,8" Text="{Binding PrimaryPanelTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <ListBox Grid.Row="1" ItemsSource="{Binding VisibleItems}" SelectedItem="{Binding SelectedVisibleItem}" DoubleTapped="OnItemRowDoubleTapped">
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="ContextMenu">
                          <ContextMenu>
                            <MenuItem Header="Exclude Item" Click="OnExcludeItemClick" />
                          </ContextMenu>
                        </Setter>
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <local:CatalogItemRowView />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <GridSplitter Grid.Row="2" Background="{DynamicResource PanelBorderBrush}" VerticalAlignment="Stretch" />
                  <TextBlock Grid.Row="3" Margin="0,8,0,8" Text="{Binding SecondaryPanelTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <ListBox Grid.Row="4" ItemsSource="{Binding SecondaryVisibleItems}" DoubleTapped="OnItemRowDoubleTapped">
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <local:CatalogItemRowView />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Column="2" Margin="7,0,0,0" IsVisible="{Binding IsUnorganizedEditorVisible}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <Border Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
                <StackPanel Spacing="10">
                  <TextBlock Text="Unorganized Editor" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.1428571429, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="Rules below remove matching items from Unorganized and place them in the blacklisted list." TextWrapping="Wrap" />
                  <TextBlock Text="Unorganized Rules" FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox Width="116" ItemsSource="{Binding RuleModes}" SelectedItem="{Binding NewUnorganizedRuleMode}" />
                    <ComboBox Width="116" ItemsSource="{Binding RuleMatches}" SelectedItem="{Binding NewUnorganizedRuleMatch}" />
                    <TextBox Width="220" Watermark="Rule term" Text="{Binding NewUnorganizedRuleTerm}" />
                    <Button Content="Add Rule" Click="OnAddUnorganizedRuleClick" />
                  </StackPanel>
                  <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding UnorganizedKeywordRules}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="120,120,*,Auto" Margin="0,0,0,6">
                              <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleModes, ElementName=RootWindow}" SelectedItem="{Binding Mode, Mode=TwoWay}" />
                              <ComboBox Grid.Column="1" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleMatches, ElementName=RootWindow}" SelectedItem="{Binding Match, Mode=TwoWay}" />
                              <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding Term, Mode=TwoWay}" />
                              <Button Grid.Column="3" Content="Remove" Click="OnRemoveUnorganizedRuleClick" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Save Rules" Click="OnSaveUnorganizedBlacklistClick" />
                    <Button Content="Clear Rules" Click="OnClearUnorganizedBlacklistClick" />
                  </StackPanel>
                  <Separator Margin="0,6,0,2" />
                  <TextBlock Text="Blacklisted Unorganized Items" FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Total:" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding BlacklistedUnorganizedCount}" Foreground="{DynamicResource TextPrimaryBrush}" />
                  </StackPanel>
                  <TextBox Watermark="Filter blacklisted items..." Text="{Binding UnorganizedBlacklistedFilterText}" />
                  <ListBox MaxHeight="360" ItemsSource="{Binding FilteredBlacklistedUnorganizedItems}" />
                </StackPanel>
              </Border>
            </ScrollViewer>
          </Border>

          <TabControl Grid.Column="2" Margin="7,0,0,0" SelectedIndex="{Binding RightEditorTabIndex}" IsVisible="{Binding IsStandardEditorVisible}">
        <TabItem Header="Category" IsVisible="{Binding IsCatalogEditorVisible}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
              <StackPanel Spacing="10">
                <TextBlock Text="Category Editor" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.1428571429, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Select a category in the tree, then edit it here." />
                <TextBlock Text="Selected category" />
                <TextBlock Text="{Binding SelectedCategoryForShop}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" />
                <TextBlock Text="Category name" />
                <TextBox Watermark="Category name" Text="{Binding NewCategoryName}" />
                <TextBlock Text="Category Rules" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <ComboBox Width="116" ItemsSource="{Binding RuleModes}" SelectedItem="{Binding NewCategoryRuleMode}" />
                  <ComboBox Width="116" ItemsSource="{Binding RuleMatches}" SelectedItem="{Binding NewCategoryRuleMatch}" />
                  <TextBox Width="220" Watermark="Rule term" Text="{Binding NewCategoryRuleTerm}" />
                  <Button Content="Add Rule" Click="OnAddCategoryRuleClick" />
                </StackPanel>
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                  <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CategoryKeywordRules}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="120,120,*,Auto" Margin="0,0,0,6">
                            <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleModes, ElementName=RootWindow}" SelectedItem="{Binding Mode, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleMatches, ElementName=RootWindow}" SelectedItem="{Binding Match, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding Term, Mode=TwoWay}" />
                            <Button Grid.Column="3" Content="Remove" Click="OnRemoveCategoryRuleClick" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
                <TextBlock Text="Category first order terms" />
                <TextBox Watermark="Category first order terms (comma/newline separated)" Text="{Binding NewCategoryFirstOrder}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="92" />
                <TextBlock Text="Category last order terms" />
                <TextBox Watermark="Category last order terms (comma/newline separated)" Text="{Binding NewCategoryLastOrder}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="92" />
                <Grid ColumnDefinitions="Auto,Auto,*">
                  <Button Content="Add Category" Click="OnAddCategoryClick" />
                  <Button Grid.Column="1" Margin="10,0,0,0" Content="Save Category" Click="OnUpdateCategoryClick" />
                  <Button Grid.Column="2" Margin="10,0,0,0" Content="Remove Category" Click="OnRemoveCategoryClick" />
                </Grid>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Shop" IsVisible="{Binding IsCatalogEditorVisible}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
              <StackPanel Spacing="10">
                <TextBlock Text="Shop Editor" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.1428571429, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Select a shop in the tree, then edit it here." />
                <TextBlock Text="Selected shop" />
                <TextBlock Text="{Binding SelectedShopName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" />
                <TextBlock Text="Shop name" />
                <TextBox Watermark="Shop name" Text="{Binding NewShopName}" />
                <TextBlock Text="Priority (lower number wins item ownership)" />
                <TextBox Watermark="Priority (integer, default 0)" Text="{Binding NewShopPriority}" />
                <TextBlock Text="Shop Rules" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <ComboBox Width="116" ItemsSource="{Binding RuleModes}" SelectedItem="{Binding NewShopRuleMode}" />
                  <ComboBox Width="116" ItemsSource="{Binding RuleMatches}" SelectedItem="{Binding NewShopRuleMatch}" />
                  <TextBox Width="220" Watermark="Rule term" Text="{Binding NewShopRuleTerm}" />
                  <Button Content="Add Rule" Click="OnAddShopRuleClick" />
                </StackPanel>
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                  <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ShopKeywordRules}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="120,120,*,Auto" Margin="0,0,0,6">
                            <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleModes, ElementName=RootWindow}" SelectedItem="{Binding Mode, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleMatches, ElementName=RootWindow}" SelectedItem="{Binding Match, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding Term, Mode=TwoWay}" />
                            <Button Grid.Column="3" Content="Remove" Click="OnRemoveShopRuleClick" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
                <TextBlock Text="Shop first order terms" />
                <TextBox Watermark="First order terms (comma/newline separated)" Text="{Binding NewShopFirstOrder}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="92" />
                <TextBlock Text="Shop last order terms" />
                <TextBox Watermark="Last order terms (comma/newline separated)" Text="{Binding NewShopLastOrder}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="92" />
                <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                  <Button Content="New Shop" Click="OnNewShopClick" />
                  <Button Grid.Column="1" Margin="10,0,0,0" Content="Save Shop" Click="OnSaveShopClick" />
                  <Button Grid.Column="2" Margin="10,0,0,0" Content="Remove Shop" Click="OnRemoveShopClick" />
                </Grid>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Conditions" IsVisible="{Binding IsCatalogEditorVisible}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
              <StackPanel Spacing="10">
                <TextBlock Text="Condition Editor" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.1428571429, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding SelectedItemName}" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBox Watermark="Filter condition options..." Text="{Binding ConditionFilterText}" IsReadOnly="{Binding IsConditionEditorReadOnly}" />
                <ScrollViewer Height="264" MinHeight="264" VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding FilteredItemConditionOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding Label}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  IsEnabled="{Binding DataContext.IsConditionEditorEnabled, ElementName=RootWindow}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Reset Item Conditions" Click="OnResetSelectedItemConditionOverrideClick" IsEnabled="{Binding IsConditionEditorEnabled}" />
                  <Button Content="Reset Shop Conditions" Click="OnResetSelectedShopConditionOverridesClick" IsEnabled="{Binding CanResetSelectedShopConditionOverrides}" />
                  <Button Content="Reset Category Conditions" Click="OnResetSelectedCategoryConditionOverridesClick" IsEnabled="{Binding CanResetSelectedCategoryConditionOverrides}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Pricing" IsVisible="{Binding IsCatalogEditorVisible}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
              <StackPanel Spacing="10">
                <TextBlock Text="Price Editor" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.1428571429, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding SelectedItemName}" Foreground="{DynamicResource TextPrimaryBrush}" />
                <Grid ColumnDefinitions="Auto,70,Auto,70,Auto,70,Auto,70" HorizontalAlignment="Left">
                  <TextBlock Text="Platinum" VerticalAlignment="Center" Margin="0,0,8,0" />
                  <TextBox Grid.Column="1" Width="70" HorizontalAlignment="Left" Text="{Binding PricePlatinum}" IsReadOnly="{Binding IsPriceEditorReadOnly}" />
                  <TextBlock Grid.Column="2" Text="Gold" VerticalAlignment="Center" Margin="10,0,8,0" />
                  <TextBox Grid.Column="3" Width="70" HorizontalAlignment="Left" Text="{Binding PriceGold}" IsReadOnly="{Binding IsPriceEditorReadOnly}" />
                  <TextBlock Grid.Column="4" Text="Silver" VerticalAlignment="Center" Margin="10,0,8,0" />
                  <TextBox Grid.Column="5" Width="70" HorizontalAlignment="Left" Text="{Binding PriceSilver}" IsReadOnly="{Binding IsPriceEditorReadOnly}" />
                  <TextBlock Grid.Column="6" Text="Copper" VerticalAlignment="Center" Margin="10,0,8,0" />
                  <TextBox Grid.Column="7" Width="70" HorizontalAlignment="Left" Text="{Binding PriceCopper}" IsReadOnly="{Binding IsPriceEditorReadOnly}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Reset Item Price" Click="OnResetSelectedItemPriceOverrideClick" IsEnabled="{Binding IsPriceEditorEnabled}" />
                  <Button Content="Reset Shop Prices" Click="OnResetSelectedShopPriceOverridesClick" IsEnabled="{Binding CanResetSelectedShopPriceOverrides}" />
                  <Button Content="Reset Category Prices" Click="OnResetSelectedCategoryPriceOverridesClick" IsEnabled="{Binding CanResetSelectedCategoryPriceOverrides}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </TabItem>
          </TabControl>
        </Grid>
      </TabItem>

      <TabItem Header="Merchants">
        <local:MerchantWorkspaceView Margin="0,8,0,0" />
      </TabItem>

      <TabItem Header="Output">
        <Grid Margin="0,8,0,0" ColumnDefinitions="360,*">
          <Border Grid.Column="0" Padding="12" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,7,0">
            <Grid RowDefinitions="Auto,*">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Output Files" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.2857142857, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <Button Grid.Column="1" Content="Open Folder" Click="OnOpenOutputFolderClick" Margin="8,0,0,0" />
              </Grid>
              <ListBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding OutputFiles}" SelectedItem="{Binding SelectedOutputFile}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <Border Grid.Column="1" Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="7,0,0,0">
            <Grid RowDefinitions="Auto,Auto,*">
              <TextBlock Text="{Binding SelectedOutputFile}" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.2857142857, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <TextBox Watermark="Search in JSON..."
                         Text="{Binding OutputSearchText}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding OutputSearchStatus}" Foreground="{DynamicResource TextMutedBrush}" />
                  <Button Content="Prev" Click="OnOutputSearchPrevClick" IsEnabled="{Binding CanOutputSearchPrev}" />
                  <Button Content="Next" Click="OnOutputSearchNextClick" IsEnabled="{Binding CanOutputSearchNext}" />
                </StackPanel>
              </Grid>
              <ScrollViewer x:Name="OutputJsonScrollViewer"
                            Grid.Row="2"
                            Margin="0,10,0,0"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock x:Name="OutputJsonPreview"
                                     FontFamily="Consolas"
                                     FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.9285714286, FallbackValue=14, TargetNullValue=14}"
                                     LineHeight="18"
                                     TextWrapping="NoWrap"
                                     Background="Transparent"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     MinWidth="{Binding Bounds.Width, ElementName=OutputJsonScrollViewer}"
                                     MinHeight="{Binding Bounds.Height, ElementName=OutputJsonScrollViewer}" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Generate">
        <Grid Margin="0,8,0,0" ColumnDefinitions="*">
          <Border Grid.Column="0" Padding="16" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="10">
              <TextBlock Text="Generate Reusable Catalog Script" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.2857142857, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Build a single C# data file from all output JSON files in catalog-data/output." TextWrapping="Wrap" />
              <TextBlock Text="The generated script is designed for easy iteration across merchants, shops, shop-slot items, conditions, and prices." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
              <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                <StackPanel Spacing="4">
                  <TextBlock Text="Output path" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="catalog-data/generated/GeneratedCatalogData.cs" FontFamily="Consolas" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="Overwrite existing file: enabled" Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Border>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Generate Script" Click="OnGenerateCatalogScriptClick" />
                <TextBlock Text="Status is shown in the bottom editor status panel." VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Stats">
        <local:StatsWorkspaceView Margin="0,8,0,0" />
      </TabItem>
    </TabControl>

        <Border x:Name="GlobalFlagsOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                Margin="-18"
                Background="#AA000000"
                PointerPressed="OnGlobalFlagsOverlayPointerPressed">
          <Grid>
        <Border MaxWidth="1520"
                MaxHeight="{Binding Bounds.Height, ElementName=GlobalFlagsOverlay}"
                MinWidth="1040"
                Margin="32,16"
                Padding="18"
                CornerRadius="14"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                PointerPressed="OnGlobalFlagsPanelPointerPressed">
          <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Global Flags" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.7142857143, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Applies to all shops. The Unorganized editor remains excluded." TextWrapping="Wrap" />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <Grid ColumnDefinitions="1.2*,1.8*">
              <Border Grid.Column="0" Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Spacing="10">
                  <TextBlock Text="First Order Items" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBox MinHeight="130"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Watermark="Comma/newline separated items sorted first globally"
                           Text="{Binding GlobalFirstOrderItems}" />
                  <TextBlock Text="Last Order Items" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                  <TextBox MinHeight="130"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Watermark="Comma/newline separated items sorted last globally"
                           Text="{Binding GlobalLastOrderItems}" />
                  <Separator Margin="0,10,0,4" />
                  <TextBlock Text="Default for unassigned items (base price 0)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <Grid ColumnDefinitions="Auto,70,Auto,70,Auto,70,Auto,70" HorizontalAlignment="Left">
                    <TextBlock Text="Platinum" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Width="70" HorizontalAlignment="Left" Text="{Binding UnassignedPricePlatinum}" />
                    <TextBlock Grid.Column="2" Text="Gold" VerticalAlignment="Center" Margin="10,0,8,0" />
                    <TextBox Grid.Column="3" Width="70" HorizontalAlignment="Left" Text="{Binding UnassignedPriceGold}" />
                    <TextBlock Grid.Column="4" Text="Silver" VerticalAlignment="Center" Margin="10,0,8,0" />
                    <TextBox Grid.Column="5" Width="70" HorizontalAlignment="Left" Text="{Binding UnassignedPriceSilver}" />
                    <TextBlock Grid.Column="6" Text="Copper" VerticalAlignment="Center" Margin="10,0,8,0" />
                    <TextBox Grid.Column="7" Width="70" HorizontalAlignment="Left" Text="{Binding UnassignedPriceCopper}" />
                  </Grid>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Save Unassigned Default" Click="OnSaveUnassignedDefaultPriceClick" />
                    <Button Content="Clear Unassigned Default" Click="OnResetUnassignedDefaultPriceClick" />
                  </StackPanel>
                  <Separator Margin="0,10,0,4" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Reset All Prices" Click="OnResetAllPricesClick" />
                    <Button Content="Reset All Conditions" Click="OnResetAllConditionsClick" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Grid Grid.Column="1" RowDefinitions="*,*" Margin="8,0,0,0">
                <Border Grid.Row="0" Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,0,7">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Whitelist Rules" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <ComboBox Width="140" ItemsSource="{Binding RuleMatches}" SelectedItem="{Binding NewGlobalWhitelistRuleMatch}" />
                      <TextBox Width="300" Watermark="Rule term" Text="{Binding NewGlobalWhitelistRuleTerm}" />
                      <Button Content="Add Rule" Click="OnAddGlobalWhitelistRuleClick" />
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                      <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GlobalWhitelistRules}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="130,*,Auto" Margin="0,0,0,6">
                                <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleMatches, ElementName=RootWindow}" SelectedItem="{Binding Match, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding Term, Mode=TwoWay}" />
                                <Button Grid.Column="2" Content="Remove" Click="OnRemoveGlobalWhitelistRuleClick" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Border>
                  </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="14" CornerRadius="12" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,7,0,0">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Blacklist Rules" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <ComboBox Width="140" ItemsSource="{Binding RuleMatches}" SelectedItem="{Binding NewGlobalBlacklistRuleMatch}" />
                      <TextBox Width="300" Watermark="Rule term" Text="{Binding NewGlobalBlacklistRuleTerm}" />
                      <Button Content="Add Rule" Click="OnAddGlobalBlacklistRuleClick" />
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                      <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GlobalBlacklistRules}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="130,*,Auto" Margin="0,0,0,6">
                                <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding DataContext.RuleMatches, ElementName=RootWindow}" SelectedItem="{Binding Match, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding Term, Mode=TwoWay}" />
                                <Button Grid.Column="2" Content="Remove" Click="OnRemoveGlobalBlacklistRuleClick" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Border>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </ScrollViewer>

          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Apply Global Flags" Click="OnApplyGlobalFlagsClick" />
            <Button Content="Close" Click="OnCloseGlobalFlagsPopupClick" />
          </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="SettingsOverlay"
            Grid.RowSpan="2"
            IsVisible="False"
            Margin="-18"
            Background="#AA000000"
            PointerPressed="OnSettingsOverlayPointerPressed">
      <Grid>
        <Border MaxWidth="1400"
                MaxHeight="{Binding Bounds.Height, ElementName=SettingsOverlay}"
              Width="1120"
              MinWidth="1040"
              MinHeight="760"
                Margin="32,16"
                Padding="18"
                CornerRadius="14"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                PointerPressed="OnSettingsPanelPointerPressed">
          <Grid RowDefinitions="Auto,*,Auto">
            <StackPanel Spacing="4">
              <TextBlock Text="Settings" FontSize="{Binding AppFontSize, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=1.7142857143, FallbackValue=14, TargetNullValue=14}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Configure tModLoader lookup, merchant NPC filters, progression flags, and text scaling." TextWrapping="Wrap" />
              <TextBlock Text="Changes save automatically." Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <TabControl Grid.Row="1" Margin="0,12,0,12" MinHeight="560" SelectedIndex="{Binding SettingsTabIndex}">
              <TabItem Header="tModLoader.dll">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="10" Margin="0,4,0,0">
                    <TextBlock Text="tModLoader.dll Path" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Used to load item IDs, NPC IDs, and progression flags from tModLoader." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBox Watermark="Full path to tModLoader.dll"
                             Text="{Binding TModLoaderDllPath}" />
                    <TextBlock Text="{Binding TModLoaderDllPathStatus}" Foreground="{DynamicResource TextMutedBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Content="Auto Detect" Click="OnAutoDetectTModLoaderClick" />
                      <TextBlock Text="Checks common Steam install locations for your OS." VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                  </StackPanel>
                </ScrollViewer>
              </TabItem>

              <TabItem Header="Filters &amp; Flag Rules">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="10" Margin="0,4,0,0">
                    <TextBlock Text="Merchant NPC Filters" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Controls which Terraria NPC IDs are treated as merchants when building the merchant list." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="Allowed Merchant NPC IDs" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox MinHeight="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="Comma or newline separated NPC IDs (e.g., Guide, Merchant, Nurse)"
                             Text="{Binding AllowedMerchantNpcIdsText}" />
                    <TextBlock Text="Always Include NPC IDs (e.g., OldMan)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox MinHeight="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="Comma or newline separated NPC IDs to always include"
                             Text="{Binding AlwaysIncludeMerchantNpcIdsText}" />

                    <Separator Margin="0,8,0,4" />

                    <TextBlock Text="Progression Flag Rules" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Used to discover world progression flags from Terraria.NPC and Terraria.Main." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="NPC Flag Prefixes (e.g., downed)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox MinHeight="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="Comma or newline separated prefixes for NPC bool fields"
                             Text="{Binding DownedFlagPrefixesText}" />
                    <TextBlock Text="Main Flags (e.g., Main.hardMode)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox MinHeight="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="Comma or newline separated Main.FieldName entries"
                             Text="{Binding MainFlagsText}" />
                  </StackPanel>
                </ScrollViewer>
              </TabItem>

              <TabItem Header="Text Scaling">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="12" Margin="0,4,0,0">
                    <TextBlock Text="Scale text for the whole app and tune tree item readability separately." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />

                    <TextBlock Text="Global app text scale" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="*,72">
                      <Slider Minimum="0.75"
                              Maximum="2.0"
                              TickFrequency="0.05"
                              IsSnapToTickEnabled="True"
                              Value="{Binding AppTextScale}" />
                      <TextBlock Grid.Column="1"
                                 Margin="10,0,0,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Text="{Binding AppTextScale, StringFormat='{}{0:F2}x'}" />
                    </Grid>

                    <TextBlock Text="Tree view text scale" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="*,72">
                      <Slider Minimum="0.75"
                              Maximum="2.0"
                              TickFrequency="0.05"
                              IsSnapToTickEnabled="True"
                              Value="{Binding TreeViewTextScale}" />
                      <TextBlock Grid.Column="1"
                                 Margin="10,0,0,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Text="{Binding TreeViewTextScale, StringFormat='{}{0:F2}x'}" />
                    </Grid>

                  </StackPanel>
                </ScrollViewer>
              </TabItem>

              <TabItem Header="Theme">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="12" Margin="0,4,0,0">
                    <TextBlock Text="Choose the app-wide theme variant." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="System follows your OS preference; Dark and Light force the theme immediately." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
                    <ComboBox Width="220"
                              ItemsSource="{Binding AppThemeOptions}"
                              SelectedItem="{Binding AppTheme}" />
                  </StackPanel>
                </ScrollViewer>
              </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
              <Button Content="Save Settings" Click="OnSaveSettingsClick" />
              <Button Content="Close" Click="OnCloseSettingsPopupClick" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Padding="14"
            CornerRadius="12"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            Margin="0,14,0,0"
            HorizontalAlignment="Left"
            Width="{Binding Bounds.Width, ElementName=WorkspaceTabs}">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MinHeight="60">
        <TextBlock Text="{Binding EditorStatus}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top" />
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
