<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MerchantsPlus.Generator"
             x:Class="MerchantsPlus.Generator.CatalogItemRowView">
  <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
    <StackPanel Orientation="Horizontal" Spacing="6">
      <TextBlock Text="{Binding Name}" Foreground="{Binding Foreground}" />
      <local:CatalogItemFlagsView />
    </StackPanel>
    <TextBlock Grid.Column="1"
               Text="{Binding PriceDisplay}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               HorizontalAlignment="Right" />
  </Grid>
</UserControl>